# --- Server ---
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Microsoft Entra SSO ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# --- Password vault (AES-256-GCM) ---
# REQUIRED in production. 32 bytes base64-encoded. Generate ONCE with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If this is unset the server auto-generates a key into data/encryption.key —
# fine for local dev, but on Railway a container restart wipes the key and
# every previously-saved customer password becomes unrecoverable. Set it
# explicitly in the Railway dashboard.
PASSWORD_ENCRYPTION_KEY=

# --- Admin allowlist ---
# Comma-separated emails (case-insensitive) allowed to download backups and
# restore from a backup zip via the Settings page. Restore is destructive, so
# keep this tight — just business owners. If unset, the backup/restore panel
# is hidden for everyone.
ADMIN_EMAILS=xander@computermechanics.com.au,amir@computermechanics.com.au
